{
  "name": "detective-ml",
  "private": true,
  "workspaces": ["frontend", "backend"],
  "scripts": {
    "dev": "npm run dev --workspace=frontend",
    "dev:backend": "npm run dev --workspace=backend",
    "dev:all": "concurrently \"npm run dev:backend\" \"npm run dev\""
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
